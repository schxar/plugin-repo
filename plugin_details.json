          },
          {
            "type": "command",
            "name": "list_expressions",
            "description": "列举表达方式（支持翻页）"
          },
          {
            "type": "command",
            "name": "delete_expression",
            "description": "删除指定的表达方式"
          },
          {
            "type": "command",
            "name": "modify_expression_weight",
            "description": "修改表达方式的权重"
          },
          {
            "type": "command",
            "name": "review_expressions",
            "description": "查看表达方式使用记录"
          },
          {
            "type": "command",
            "name": "learn_expression",
            "description": "学习表达方式"
          },
          {
            "type": "command",
            "name": "analyze_message_expression",
            "description": "分析消息表达方式"
          }
        ],
        "features": [
          "添加表达方式（语言风格和句法特点）",
          "分页列举表达方式",
          "删除表达方式",
          "修改表达方式权重",
          "支持按群组管理",
          "查看表达方式使用记录",
          "学习表达方式",
          "分析消息表达方式"
        ]
      }
    }
